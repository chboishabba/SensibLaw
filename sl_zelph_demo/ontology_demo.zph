court_international_criminal_court "kind" court

court_international_court_of_justice "canonical label" "International Court of Justice"
court_international_court_of_justice "wikidata id" Q7801
court_international_court_of_justice "kind" court

court_u_s_supreme_court "canonical label" "Supreme Court of the United States"
court_u_s_supreme_court "wikidata id" Q11201
court_u_s_supreme_court "kind" court

institution_united_states_department_of_defense "canonical label" "United States Department of Defense"
institution_united_states_department_of_defense "wikidata id" Q11209
institution_united_states_department_of_defense "kind" institution

institution_u_s_senate "canonical label" "United States Senate"
institution_u_s_senate "wikidata id" Q66096
institution_u_s_senate "kind" institution

institution_u_s_house_of_representatives "canonical label" "United States House of Representatives"
