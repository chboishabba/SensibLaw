# SensibLaw x Zelph - Ontology Bridge Demo
# Run: zelph ontology_demo.zph
# All facts and rules in one script. Queries at the end produce real deduced answers.

# --- Wikidata Bridge Bodies (from data/ontology/wikidata_bridge_bodies_gwb_v1.json) ---

institution_united_nations "canonical label" "United Nations"
institution_united_nations "wikidata id" Q1065
institution_united_nations "kind" institution

institution_united_nations_security_council "canonical label" "United Nations Security Council"
institution_united_nations_security_council "wikidata id" Q37470
institution_united_nations_security_council "kind" institution

