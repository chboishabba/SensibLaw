institution_central_intelligence_agency "canonical label" "Central Intelligence Agency"
institution_central_intelligence_agency "wikidata id" Q37230
institution_central_intelligence_agency "kind" institution

institution_federal_bureau_of_investigation "canonical label" "Federal Bureau of Investigation"
institution_federal_bureau_of_investigation "wikidata id" Q8333
institution_federal_bureau_of_investigation "kind" institution

# --- AU Semantic Linkage (from data/ontology/au_semantic_linkage_seed_v1.json) ---

au_semantic_mabo_native_title "court authority" court_high_court_of_australia
au_semantic_mabo_native_title "has tag" constitutional
au_semantic_mabo_native_title "has tag" native_title

au_semantic_plaintiff_s157_judicial_review "court authority" court_high_court_of_australia
au_semantic_plaintiff_s157_judicial_review "has tag" constitutional
au_semantic_plaintiff_s157_judicial_review "has tag" migration

au_semantic_house_error_of_principle "court authority" court_high_court_of_australia
au_semantic_house_error_of_principle "has tag" criminal
au_semantic_house_error_of_principle "has tag" appeal

au_semantic_civil_liability_act_lane "has tag" duty_of_care
au_semantic_civil_liability_act_lane "has tag" attribution

# --- Wrong Type Catalog (from data/ontology/wrong_type_catalog_seed.yaml) ---

assault_common "wrong type in" AU_COMMON
assault_common "protects interest" bodily_integrity
assault_common "wrong source" "Crimes Act 1900 (NSW) s 59"

larceny_statute "wrong type in" AU_COMMON
larceny_statute "protects interest" property_security
larceny_statute "wrong source" "Crimes Act 1900 (NSW) ss 117-118"

mana_diminution "wrong type in" NZ_TIKANGA
mana_diminution "protects interest" mana_preservation
mana_diminution "wrong source" "Wai 2500 Te Rohe Potae Inquiry"

gdpr_unlawful_processing "wrong type in" EU
gdpr_unlawful_processing "protects interest" data_privacy
gdpr_unlawful_processing "wrong source" "GDPR Articles 6-7"

equality_direct_discrimination "wrong type in" EU
equality_direct_discrimination "protects interest" equality_non_discrimination
equality_direct_discrimination "wrong source" "Directive 2000/43/EC art 2"

# --- Rules ---

# Rule 1: Lanes touching both HCA and constitutional tag -> inferred as "constitutional high court matter"
(L "court authority" court_high_court_of_australia, L "has tag" constitutional) => (L "is" "constitutional high court matter")

# Rule 2: International courts by Wikidata Q-ID
(A "wikidata id" Q7801)  => (A "is" "international court")
(A "wikidata id" Q47488) => (A "is" "international court")

# Rule 3: US Federal institutions by Wikidata Q-ID
(A "wikidata id" Q11201) => (A "is" "US federal institution")
(A "wikidata id" Q11209) => (A "is" "US federal institution")
(A "wikidata id" Q66096) => (A "is" "US federal institution")
(A "wikidata id" Q11701) => (A "is" "US federal institution")
(A "wikidata id" Q37230) => (A "is" "US federal institution")
(A "wikidata id" Q8333)  => (A "is" "US federal institution")

# Rule 4: Wrong types protecting bodily integrity trigger civil remedy potential
(W "protects interest" bodily_integrity, W "wrong type in" S) => (W "may trigger" "civil remedy")

# --- Queries (variables = uppercase single letters, or _Prefixed) ---
# These run immediately after the facts+rules are loaded

L "is" "constitutional high court matter"
A "is" "international court"
A "is" "US federal institution"
W "may trigger" "civil remedy"
