# Optional Wikidata live-replay identity. Keep actual values in a local .env
# (ignored by git) and source it before invoking the materializer.
SENSIBLAW_WIKIDATA_CONTACT_NAME=
SENSIBLAW_WIKIDATA_CONTACT_EMAIL=

# Optional OAuth 2 access token. Never commit a token or place it in artifacts.
SENSIBLAW_WIKIDATA_OAUTH_ACCESS_TOKEN=
